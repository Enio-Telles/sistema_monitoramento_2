# Oracle Connection Configuration
# ================================
# Oracle Host
ORACLE_HOST=exa01-scan.sefin.ro.gov.br

# Oracle Port (default: 1521)
ORACLE_PORT=1521

# Oracle Service Name
ORACLE_SERVICE=sefindw

# Database Credentials
# =====================

# Database User (CPF or username)
DB_USER=your_db_user_here

# Database Password
DB_PASSWORD=your_db_password_here

# Oracle Host
ORACLE_HOST_1=exacc-x10-sefinscan.sefin.ro.gov.br

# Oracle Port (default: 1521)
ORACLE_PORT_1=1521

# Oracle Service Name
ORACLE_SERVICE_1=svc.bi.users

# Database Credentials
# =====================

# Database User (CPF or username)
DB_USER_1=your_db_user_here

# Database Password
DB_PASSWORD_1=your_db_password_here

# Application Settings
# ====================

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL=3600

# Dashboard Settings
DASHBOARD_THEME=dark
DASHBOARD_WIDTH=wide

# Visão Contribuinte
Login_Visao_360=your_visao_login_here
Senha_Visao_350=your_visao_senha_here

# ==================== PostgreSQL (local) ====================
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_pg_password_here
SAVED_ORACLE_USER=your_saved_oracle_user_here
