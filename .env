
# Oracle Connection Configuration
# ================================
# Oracle Host
ORACLE_HOST=exa01-scan.sefin.ro.gov.br

# Oracle Port (default: 1521)
ORACLE_PORT=1521

# Oracle Service Name
ORACLE_SERVICE=sefindw

# Database Credentials
# =====================

# Database User (CPF or username)
DB_USER=YOUR_CPF_HERE

# Database Password
DB_PASSWORD=YOUR_PASSWORD_HERE

# Oracle Host
ORACLE_HOST_1=exacc-x10-sefinscan.sefin.ro.gov.br

# Oracle Port (default: 1521)
ORACLE_PORT_1=1521

# Oracle Service Name
ORACLE_SERVICE_1=svc.bi.users

# Database Credentials
# =====================

# Database User (CPF or username)
DB_USER_1=OTHER_CPF_HERE

# Database Password
DB_PASSWORD_1=OTHER_PASSWORD_HERE

# Application Settings
# ====================

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL=3600

# Dashboard Settings
DASHBOARD_THEME=dark
DASHBOARD_WIDTH=wide

# Visão Contribuinte
Login_Visao_360=YOUR_CPF_HERE
Senha_Visao_350=YOUR_PASSWORD_HERE

# ==================== PostgreSQL (local) ====================
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=sefin
SAVED_ORACLE_USER=YOUR_CPF_HERE

# Paths
SISTEMA_MONITORAMENTO=C:\path\to\sistema_monitoramento
